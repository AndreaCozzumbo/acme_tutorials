# GCN Kafka Credentials
# Get your credentials at: https://gcn.nasa.gov/quickstart
GCN_CLIENT_ID=your_client_id_here
GCN_CLIENT_SECRET=your_client_secret_here

# Slack Bot Token
# Get your token at: https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_CHANNEL_ID=your-channel-id-here

# Telegram Bot Token
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# Email Configuration (if needed)
EMAIL_SENDER=your-email@example.com
EMAIL_PASSWORD=your-app-password-here
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
