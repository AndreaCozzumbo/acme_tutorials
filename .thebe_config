{
  "binderOptions": {
    "repo": "samueleronchini/acme_tutorials",
    "ref": "main",
    "binderUrl": "https://mybinder.org",
    "repoProvider": "github"
  },
  "kernelOptions": {
    "name": "python3",
    "kernelName": "python3"
  },
  "selector": "div.thebelab-cell",
  "requestKernel": true,
  "predefinedOutput": true,
  "mountActivateWidget": true,
  "mountStatusWidget": true,
  "bootstrap": true
}
